@page
@model ShippingDetailsModel

<h2>Shipping Details</h2>

<p>Please enter your shipping information below.</p>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="ShippingInfo.FullName"></label>
        <input asp-for="ShippingInfo.FullName" class="form-control" />
        <span asp-validation-for="ShippingInfo.FullName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ShippingInfo.AddressLine1"></label>
        <input asp-for="ShippingInfo.AddressLine1" class="form-control" />
        <span asp-validation-for="ShippingInfo.AddressLine1" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ShippingInfo.AddressLine2"></label>
        <input asp-for="ShippingInfo.AddressLine2" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="ShippingInfo.City"></label>
        <input asp-for="ShippingInfo.City" class="form-control" />
        <span asp-validation-for="ShippingInfo.City" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ShippingInfo.Postcode"></label>
        <input asp-for="ShippingInfo.Postcode" class="form-control" />
        <span asp-validation-for="ShippingInfo.Postcode" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ShippingInfo.Email"></label>
        <input asp-for="ShippingInfo.Email" class="form-control" />
        <span asp-validation-for="ShippingInfo.Email" class="text-danger"></span>
    </div>
    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">
            Continue
        </button>
    </div>
</form>