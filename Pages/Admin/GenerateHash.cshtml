@page
@model GenerateHashModel

<h2>Generate Admin Password Hash</h2>

<p>
    Enter the password you want to use for the admin area.
    When you submit the form, the application will generate a one‑way hash that you can paste into
    <code>appsettings.development.json</code>.
</p>

<form method="post">
    <div class="mb-3">
        <label asp-for="Password" class="form-label">Password</label>
        <input asp-for="Password" type="password" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Generate Hash</button>
</form>

@if (Model.Hash != null)
{
    <div class="alert alert-success mt-3">
        <strong>Your Hash:</strong>
        <pre>@Model.Hash</pre>
        <p>Copy this value into <code>appsettings.development.json</code> under <code>Admin:PasswordHash</code>.</p>
    </div>
}