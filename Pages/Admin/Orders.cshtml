@page
@model OrdersModel

<h2>Orders</h2>

<!-- Search box -->
<form method="get" class="mb-3">
    <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search orders...">
</form>

<!-- Orders list -->
<div class="orders-list">

    @foreach (var order in Model.Orders)
    {
        <details class="mb-2 border rounded p-2">
            <summary class="d-flex justify-content-between align-items-center">

                <!-- Summary left side -->
                <span>
                    <strong>Order #@order.Id</strong>
                    — @order.ShippingInfo.FullName
                    — @order.ShippingInfo.Email
                </span>

                <!-- Summary right side -->
                <span>
                    @order.Total.ToString("C")
                    —
                    <span class="badge bg-@(order.OrderStatus == "Paid" ? "success" : "secondary")">
                        @order.OrderStatus
                    </span>
                    —
                    @order.OrderDate.ToString("dd MMM yyyy")
                </span>

            </summary>

            <!-- Expanded section -->
            <div class="mt-3">

                <!-- Customer details -->
                <h6>Customer Details</h6>
                <p><strong>Name:</strong> @order.ShippingInfo.FullName</p>
                <p><strong>Email:</strong> @order.ShippingInfo.Email</p>
                <p><strong>Address:</strong> @order.ShippingInfo.AddressLine1</p>
                <p><strong>Postcode:</strong> @order.ShippingInfo.Postcode</p>

                <!-- Order details -->
                <h6 class="mt-3">Order Details</h6>
                <p><strong>Order ID:</strong> @order.Id</p>
                <p><strong>Date:</strong> @order.OrderDate.ToString("dd MMM yyyy")</p>
                <p><strong>Status:</strong> @order.OrderStatus</p>
                <p><strong>Verification Code:</strong> @order.VerificationCode</p>

                <!-- Items table -->
                <h6 class="mt-3">Items</h6>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Price</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.Items)
                        {
                            <tr>
                                <td>@item.Product.Name</td>
                                <td>@item.Quantity</td>
                                <td>@item.Price.ToString("C")</td>
                                <td>@((item.Price * item.Quantity).ToString("C"))</td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </details>
    }

</div>