@page
@using Storefront.Models
@model OrdersModel

<h2>Orders</h2>

<!-- Search box -->
<form method="get" class="mb-3">
    <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search orders...">
</form>

<!-- Orders list -->
<div class="orders-list">

    @for (int i = 0; i < Model.Orders.Count; i++)
    {
        var order = Model.Orders[i];

        <details class="mb-2 border rounded p-2">
            <summary class="d-flex justify-content-between align-items-center">

                <!-- Summary left side -->
                <span>
                    <strong>Order #@order.Id</strong>
                    — @order.ShippingInfo.FullName
                    — @order.ShippingInfo.Email
                </span>

                <!-- Summary right side -->
                <span>
                    @order.Total.ToString("C")
                    —
                    <span class="badge bg-@(order.OrderStatus == OrderStatusConstants.Paid ? "success" : "secondary")">
                        @order.OrderStatus
                    </span>
                    —
                    @order.OrderDate.ToString("dd MMM yyyy")
                </span>

            </summary>
            <!-- Expanded section -->
            <div class="mt-3">
                <form method="post">
                    <input type="hidden" name="orderId" value="@order.Id" />
                    <!-- Customer details -->
                    <h6>Customer Details</h6>
                    <p><strong>Name:</strong> @order.ShippingInfo.FullName</p>
                    <p><strong>Email:</strong> @order.ShippingInfo.Email</p>
                    <p><strong>Address:</strong> @order.ShippingInfo.AddressLine1</p>
                    <p><strong>Postcode:</strong> @order.ShippingInfo.Postcode</p>
                    <!-- Order details -->
                    <h6 class="mt-3">Order Details</h6>
                    <p><strong>Order ID:</strong> @order.Id</p>
                    <p><strong>Date:</strong> @order.OrderDate.ToString("dd MMM yyyy")</p>
                    <div class="form-group d-flex align-items-end gap-2">
                        <label for="status-@i"><strong>Status:</strong></label>
                        <select asp-for="Orders[i].OrderStatus" class="form-control">
                            <option value="@OrderStatusConstants.Pending">Pending</option>
                            <option value="@OrderStatusConstants.Paid">Paid</option>
                            <option value="@OrderStatusConstants.Processing">Processing</option>
                            <option value="@OrderStatusConstants.Shipped">Shipped</option>
                            <option value="@OrderStatusConstants.Completed">Completed</option>
                            <option value="@OrderStatusConstants.Cancelled">Cancelled</option>
                        </select>
                        <button type="submit" class="btn btn-primary mt-2">Save</button>
                    </div>
                    <p><strong>Verification Code:</strong> @order.VerificationCode</p>
                    <!-- Items table -->
                    <h6 class="mt-3">Items</h6>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Qty</th>
                                <th>Price</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in order.Items)
                            {
                                <tr>
                                    <td>@item.Product.Name</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.Price.ToString("C")</td>
                                    <td>@((item.Price * item.Quantity).ToString("C"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </form>
            </div>
        </details>
    }
</div>